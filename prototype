const FLOW_ORDER = [
  "splash", "trailer", "trust", "entry", "register", "emailotp", "mobile", "mobileotp",
  "devicetrust", "naomiintro", "voiceintro", "interviewdone", "processing", "profileready",
  "celebration", "dna", "badge1intro", "badge1doc", "badge1bio", "badge1age", "badge1done",
  "badge2intro", "badge2doc", "badge2done", "badge3intro", "badge3wait", "badge3done",
  "activation", "end",
];

const SECTION_LABELS = {
  splash: "Awareness", trailer: "Awareness", trust: "Awareness",
  entry: "Onboarding", register: "Onboarding", emailotp: "Onboarding", mobile: "Onboarding", mobileotp: "Onboarding", devicetrust: "Onboarding",
  naomiintro: "Interview", voiceintro: "Interview", textintro: "Interview", schedule: "Interview", interviewdone: "Interview",
  processing: "DNA Profile", profileready: "DNA Profile", celebration: "DNA Profile", dna: "DNA Profile",
  badge1intro: "Verification L1", badge1doc: "Verification L1", badge1bio: "Verification L1", badge1age: "Verification L1", badge1done: "Verification L1",
  badge2intro: "Verification L2", badge2doc: "Verification L2", badge2done: "Verification L2",
  badge3intro: "Verification L3", badge3wait: "Verification L3", badge3done: "Verification L3",
  activation: "Activation", end: "Activation",
};

export default function NaomiPrototype() {
  const [screen, setScreen] = useState("splash");
  const [history, setHistory] = useState(["splash"]);

  const go = (id) => {
    if (!ROUTES[id]) return;
    setScreen(id);
    setHistory((h) => [...h, id]);
  };
  const back = () => {
    setHistory((h) => {
      if (h.length < 2) return h;
      const nh = h.slice(0, -1);
      setScreen(nh[nh.length - 1]);
      return nh;
    });
  };
  const jumpTo = (id) => {
    setScreen(id);
    setHistory((h) => [...h, id]);
  };

  const Comp = ROUTES[screen];
  const statusDark = ["splash", "trailer", "devicetrust", "processing", "activation"].includes(screen);
  const idx = FLOW_ORDER.indexOf(screen);

  return (
    <div
      style={{
        minHeight: "100vh",
        background: `radial-gradient(circle at 20% 10%, #F5EEDD, ${C.paperDeep} 70%)`,
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        padding: "40px 16px 60px",
        fontFamily: fontBody,
      }}
    >
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,500&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      />

      <div style={{ textAlign: "center", marginBottom: 28, maxWidth: 480 }}>
        <div style={{ fontFamily: fontMono, fontSize: 11, letterSpacing: "0.16em", textTransform: "uppercase", color: C.clayDeep, marginBottom: 8 }}>
          Naomi · Clickable Prototype
        </div>
        <h1 style={{ fontFamily: fontDisplay, fontSize: 28, color: C.ink, margin: 0 }}>
          Awareness → Onboarding → Relationship DNA → Activation
        </h1>
        <p style={{ fontSize: 13, color: C.inkSoft, marginTop: 8 }}>
          Click through the phone like a real user. Matching &amp; first-date flows are out of scope for this pass.
        </p>
      </div>

      <div style={{ display: "flex", gap: 28, alignItems: "flex-start" }}>
        <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 14 }}>
          <PhoneFrame statusDark={statusDark}>
            <Comp go={go} />
          </PhoneFrame>
          <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
            <button
              onClick={back}
              disabled={history.length < 2}
              style={{
                padding: "9px 16px",
                borderRadius: 10,
                border: `1px solid ${C.line}`,
                background: C.cream,
                fontSize: 12.5,
                cursor: history.length < 2 ? "default" : "pointer",
                opacity: history.length < 2 ? 0.4 : 1,
                fontFamily: fontBody,
              }}
            >
              ← Back
            </button>
            <div
              style={{
                fontFamily: fontMono,
                fontSize: 11,
                color: C.inkSoft,
                padding: "9px 14px",
                borderRadius: 10,
                background: C.paperDeep,
              }}
            >
              {SECTION_LABELS[screen] || "—"} · {idx >= 0 ? idx + 1 : "?"}/{FLOW_ORDER.length}
            </div>
          </div>
        </div>

        {/* Jump nav */}
        <div
          style={{
            width: 230,
            maxHeight: 740,
            overflowY: "auto",
            background: C.cream,
            border: `1px solid ${C.line}`,
            borderRadius: 18,
            padding: 16,
          }}
        >
          <div style={{ fontFamily: fontMono, fontSize: 10.5, letterSpacing: "0.1em", textTransform: "uppercase", color: C.inkSoft, marginBottom: 12 }}>
            Jump to screen
          </div>
          {Object.entries(
            FLOW_ORDER.reduce((acc, id) => {
              const sec = SECTION_LABELS[id] || "—";
              (acc[sec] = acc[sec] || []).push(id);
              return acc;
            }, {})
          ).map(([sec, ids]) => (
            <div key={sec} style={{ marginBottom: 10 }}>
              <div style={{ fontSize: 11, fontWeight: 700, color: C.clayDeep, marginBottom: 5 }}>{sec}</div>
              <div style={{ display: "flex", flexDirection: "column", gap: 3 }}>
                {ids.map((id) => (
                  <button
                    key={id}
                    onClick={() => jumpTo(id)}
                    style={{
                      textAlign: "left",
                      padding: "6px 9px",
                      borderRadius: 8,
                      border: "none",
                      background: screen === id ? "#FBF1EE" : "transparent",
                      color: screen === id ? C.clayDeep : C.ink,
                      fontWeight: screen === id ? 700 : 400,
                      fontSize: 12,
                      cursor: "pointer",
                    }}
                  >
                    {id}
                  </button>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

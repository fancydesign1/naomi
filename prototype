      </div>
      <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
        {checks.map((c, i) => (
          <div key={c} style={{ display: "flex", alignItems: "center", gap: 12 }}>
            <div
              style={{
                width: 20,
                height: 20,
                borderRadius: "50%",
                border: `1.5px solid ${i < done ? C.gold : "rgba(255,252,246,0.3)"}`,
                background: i < done ? C.gold : "transparent",
                display: "flex",

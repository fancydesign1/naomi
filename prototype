  return (
    <Screen bg={C.navy} justify="center" pad={28}>
      <div style={{ textAlign: "center", marginBottom: 32 }}>
        <div style={{ fontFamily: fontDisplay, color: C.cream, fontSize: 20, marginBottom: 6 }}>
          Securing your account

// ---------- Trust Thread (signature element) ----------
// A vertical strand that accumulates as the user passes through verification.
// stage: 0 none, 1 L1 done, 2 L2 done, 3 L3 done (gold = DNA complete)
function TrustThread({ stage, height = 36 }) {
  const segs = [0, 1, 2];
  return (
    <div style={{ display: "flex", alignItems: "center", gap: 4, height }}>
      {segs.map((s) => {
        const done = stage > s;
        const current = stage === s;
        return (
          <div
            key={s}
            style={{
              width: 26,
              height: 5,
              borderRadius: 4,
              background: done ? (stage >= 3 ? C.gold : C.navy) : current ? C.clay : C.line,
              transition: "background 0.3s ease",
            }}
          />
        );
      })}
    </div>
  );
}


// SCREEN 6 — Email OTP
// ============================================================
function OtpScreen({ go, next, title, sub, digits = 6 }) {
  const [code, setCode] = useState(["", "", "", "", "", ""].slice(0, digits));
  const [seconds, setSeconds] = useState(42);
  useEffect(() => {
    const t = setInterval(() => setSeconds((s) => (s > 0 ? s - 1 : 0)), 1000);
    return () => clearInterval(t);
  }, []);
  const filled = code.filter(Boolean).length;
  return (
    <Screen pad={28} justify="space-between">
      <div>
        <ScreenLabel>{sub}</ScreenLabel>
        <h1 style={{ fontFamily: fontDisplay, fontSize: 24, margin: "8px 0 8px" }}>{title}</h1>
        <p style={{ fontSize: 13, color: C.inkSoft, marginBottom: 24 }}>
          Enter the {digits}-digit code we sent you.
        </p>
        <div style={{ display: "flex", gap: 8, justifyContent: "center" }}>
          {code.map((c, i) => (
            <div
              key={i}
              onClick={() => {
                const next = [...code];
                next[i] = next[i] ? "" : "•";
                setCode(next);
              }}
              style={{
                width: 38,
                height: 48,
                borderRadius: 10,
                border: `1.5px solid ${c ? C.clay : C.line}`,
                background: C.cream,
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                fontSize: 20,
                cursor: "pointer",
                color: C.clay,
              }}
            >
              {c}
            </div>
          ))}
        </div>
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 18 }}>
          <TextLink onClick={() => setSeconds(42)}>{seconds > 0 ? `Resend in 0:${seconds.toString().padStart(2, "0")}` : "Resend code"}</TextLink>
          <TextLink>Wrong number?</TextLink>
        </div>
      </div>
      <PrimaryButton onClick={() => go(next)} style={{ opacity: filled === digits ? 1 : 0.45 }}>
        Verify
      </PrimaryButton>
    </Screen>
  );
}


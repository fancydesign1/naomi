function TextInterviewScreen({ go }) {
  const [qi, setQi] = useState(0);
  const [draft, setDraft] = useState("");
  const [history, setHistory] = useState([]);
  const endRef = useRef(null);
  useEffect(() => {
    endRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [history, qi]);
  const done = qi >= QIC_QUESTIONS.length;
  const submit = () => {
    if (!draft.trim()) return;
    setHistory((h) => [...h, { q: QIC_QUESTIONS[qi], a: draft }]);
    setDraft("");
    setQi((q) => q + 1);
  };
  return (
    <Screen pad={18} justify="space-between" bg={C.paperDeep}>
      <div style={{ overflowY: "auto" }}>
        <ScreenLabel>naomi · text interview · {Math.min(qi + 1, QIC_QUESTIONS.length)}/{QIC_QUESTIONS.length}</ScreenLabel>
        <div style={{ marginTop: 10 }}>
          {history.map((h, i) => (
            <React.Fragment key={i}>
              <NaomiBubble>{h.q}</NaomiBubble>
              <UserBubble>{h.a}</UserBubble>
            </React.Fragment>
          ))}
          {!done && <NaomiBubble>{QIC_QUESTIONS[qi]}</NaomiBubble>}
          {done && <NaomiBubble>It was a pleasure getting to know you. Now we can begin creating your profile.</NaomiBubble>}
          <div ref={endRef} />
        </div>
      </div>
      <div>
        {!done ? (
          <div style={{ display: "flex", gap: 8 }}>
            <input
              value={draft}
              onChange={(e) => setDraft(e.target.value)}
              onKeyDown={(e) => e.key === "Enter" && submit()}
              placeholder="Type your answer…"
              style={{
                flex: 1,
                padding: "13px 14px",
                borderRadius: 12,
                border: `1px solid ${C.line}`,
                background: C.cream,
                fontFamily: fontBody,
                fontSize: 14,
                outline: "none",
              }}
            />
            <button
              onClick={submit}
              style={{
                width: 46,
                borderRadius: 12,
                border: "none",
                background: C.clay,
                color: C.cream,
                fontSize: 16,
                cursor: "pointer",
              }}
            >
              →
            </button>
          </div>
        ) : (
          <PrimaryButton onClick={() => go("interviewdone")}>Continue</PrimaryButton>
        )}
      </div>
    </Screen>
  );
}

